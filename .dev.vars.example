# Copy to .dev.vars for local development (do not commit .dev.vars).
# Map style JSON URL. Leave empty to use the built-in OSM raster style.
MAP_STYLE_URL=
APP_VERSION=0.1.0

# ---- Cloudflare Turnstile (human verification for write actions) ----
# The SECRET key must never reach the client. Keep it here for local dev,
# and set it with `wrangler secret put TURNSTILE_SECRET_KEY` in production.
#
# Cloudflare-provided TEST keys (https://developers.cloudflare.com/turnstile/troubleshooting/testing/):
#   site key (always passes):   1x00000000000000000000AA   -> set in wrangler.toml [vars]
#   secret   (always passes):   1x0000000000000000000000000000000AA
#   site key (always blocks):   2x00000000000000000000AB
#   secret   (always fails):    2x0000000000000000000000000000000AA
#
# For local dev, the always-pass test secret:
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
